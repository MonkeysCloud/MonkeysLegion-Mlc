{
  "name": "monkeyscloud/monkeyslegion-mlc",
  "description": "`.mlc` MonkeysLegion Config format parser & loader - Production-ready configuration management",
  "type": "library",
  "license": "MIT",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "keywords": [
    "config",
    "configuration",
    "mlc",
    "monkeyslegion",
    "parser",
    "cache"
  ],
  "require": {
    "php": "^8.4",
    "monkeyscloud/monkeyslegion-cache": "^1.0",
    "monkeyscloud/monkeyslegion-env": "^1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.10",
    "friendsofphp/php-cs-fixer": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "MonkeysLegion\\Mlc\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "MonkeysLegion\\Mlc\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse src --level=9",
    "cs-fix": "php-cs-fixer fix src",
    "ci": [
      "@analyse",
      "@test"
    ]
  },
  "extra": {
    "branch-alias": {
      "dev-main": "2.0.x-dev"
    }
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true,
    "preferred-install": "dist"
  }
}
